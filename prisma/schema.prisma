generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Node {
  id                    String      @id @default(uuid()) @db.Uuid
  nodeId                String      @unique
  ownerUserId           String?
  status                String      @default("pending_registration")
  isOnline              Boolean     @default(false)
  isTrusted             Boolean     @default(false)
  trustLevel            String      @default("community")
  remoteIp              String?
  ipVersion             Int?
  countryCode           String?
  regionCode            String?
  city                  String?
  asn                   Int?
  ispOrOrg              String?
  connectedAt           DateTime?
  checksToday           Int         @default(0)
  checksLastHour        Int         @default(0)
  lastAssignedAt        DateTime?
  validationAccuracy    Float?
  claimTokenHash        String?
  claimTokenUsedAt      DateTime?
  publicKey             String?
  serverPublicKeySentAt DateTime?
  activatedAt           DateTime?
  lastSeenAt            DateTime?
  agentVersion          String?
  hardwareRaw           Json?
  hardwareFingerprint   String?
  region                String?
  reputationScore       Int         @default(50)
  createdAt             DateTime    @default(now())
  results               JobResult[]
  checkAssignments      CheckAssignment[]
  checkResults          CheckResult[]
  reputationEvents      NodeReputationEvent[]

  @@map("nodes")
}

model Job {
  id             String      @id @default(uuid()) @db.Uuid
  type           String
  target         String
  status         String      @default("pending")
  createdAt      DateTime    @default(now())
  assignedNodeId String?
  results        JobResult[]

  @@map("jobs")
}

model JobResult {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @db.Uuid
  nodeId    String
  status    String
  latencyMs Int?
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  node      Node     @relation(fields: [nodeId], references: [nodeId], onDelete: Cascade)

  @@map("job_results")
}

model CheckDefinition {
  id                    String           @id @default(uuid()) @db.Uuid
  type                  String
  target                String
  intervalSec           Int
  isActive              Boolean          @default(true)
  nextRunAt             DateTime
  validationMode        String           @default("on_failure")
  validationCount       Int              @default(2)
  requiredRegion        String?
  minReputation         Int?
  maxReputation         Int?
  preferTrusted         Boolean          @default(false)
  requireTrusted        Boolean          @default(false)
  preferDifferentAsn    Boolean          @default(true)
  preferDifferentRegion Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  executions            CheckExecution[]

  @@map("check_definitions")
}

model CheckExecution {
  id              String            @id @default(uuid()) @db.Uuid
  checkDefinitionId String          @db.Uuid
  status          String            @default("pending")
  consensusStatus String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  checkDefinition CheckDefinition   @relation(fields: [checkDefinitionId], references: [id], onDelete: Cascade)
  assignments     CheckAssignment[]
  results         CheckResult[]
  reputationEvents NodeReputationEvent[]

  @@map("check_executions")
}

model CheckAssignment {
  id          String         @id @default(uuid()) @db.Uuid
  executionId String         @db.Uuid
  nodeId      String
  role        String
  status      String         @default("assigned")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  execution   CheckExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  node        Node           @relation(fields: [nodeId], references: [nodeId], onDelete: Cascade)
  result      CheckResult?
  reputationEvents NodeReputationEvent[]

  @@map("check_assignments")
}

model CheckResult {
  id           String         @id @default(uuid()) @db.Uuid
  executionId  String         @db.Uuid
  assignmentId String         @unique @db.Uuid
  nodeId       String
  status       String
  latencyMs    Int?
  createdAt    DateTime       @default(now())
  execution    CheckExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  assignment   CheckAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  node         Node           @relation(fields: [nodeId], references: [nodeId], onDelete: Cascade)

  @@map("check_results")
}

model NodeReputationEvent {
  id           String          @id @default(uuid()) @db.Uuid
  nodeId       String
  executionId  String?         @db.Uuid
  assignmentId String?         @db.Uuid
  eventType    String
  scoreDelta   Int
  reason       String
  createdAt    DateTime        @default(now())
  node         Node            @relation(fields: [nodeId], references: [nodeId], onDelete: Cascade)
  execution    CheckExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)
  assignment   CheckAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@unique([assignmentId, eventType])
  @@map("node_reputation_events")
}
